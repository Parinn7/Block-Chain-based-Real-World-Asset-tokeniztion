# ─── Blockchain ───────────────────────────────────────────────────────────────
# Your Metamask wallet private key (NEVER commit this to git)
PRIVATE_KEY=your_metamask_private_key_here

# Get a free RPC URL from Alchemy (https://alchemy.com) or Infura (https://infura.io)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Get from https://etherscan.io/myapikey (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Paste deployed contract address here after running deploy script
REACT_APP_CONTRACT_ADDRESS=0x...

# Pinata IPFS credentials (https://pinata.cloud) — free tier available
REACT_APP_PINATA_API_KEY=your_pinata_api_key
REACT_APP_PINATA_SECRET=your_pinata_secret_key
